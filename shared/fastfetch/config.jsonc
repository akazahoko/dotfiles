// Reference: https://github.com/fastfetch-cli/fastfetch/wiki/Configuration
{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
  "logo": {
    "type": "chafa",
    "width": 45,
    "source": "~/.config/fastfetch/logos/asn.png"
  },
  "display": {
    "separator": ": ",
    "key": {
      "width": 20,
      "type": "both"
    },
    "bar": {
      "char": {
        "elapsed": "■",
        "total": "-"
      }
    },
    "percent": {
      "type": 2
    }
  },
  "modules": [
    "title",
    "separator",
    "os",
    "host",
    "kernel",
    "uptime",
    "packages",
    "shell",
    "separator",
    "de",
    "wm",
    "terminal",
    "separator",
    "theme",
    // "wmtheme",
    "icons",
    "font",
    "cursor",
    "terminalfont",
    "separator",
    {
      "type": "display",
      "key": "Display",
      "format": "{name} {inch}\" {width}x{height} @ {refresh-rate}Hz"
    },
    {
      "type": "cpu",
      "key": "CPU",
      "format": "{name}"
    },
    {
      "type": "gpu",
      "key": "GPU",
      "format": "{vendor} {name}"
    },
    "memory",
    "swap",
    {
      "type": "disk",
      "key": "Disk",
      "format": "{size-percentage-bar} {size-used} / {size-total}"
    },
    "separator",
    {
      "type": "localip",
      "key": "IP",
      "format": "{ipv4}"
    },
    "locale",
    "break"
    // "colors"
  ]
}