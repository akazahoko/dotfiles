// Reference: https://github.com/Alexays/Waybar/wiki/Configuration
{
    "position": "bottom",
    "height": 40,
    "spacing": 0,
    "include": [ 
        "./modules/separator.jsonc",
        "./modules/hyprland.jsonc",
        "./modules/mpris.jsonc",
        "./modules/power-profiles-daemon.jsonc",
        "./modules/privacy.jsonc",
        "./modules/clocks/normal.jsonc",
        "./modules/clean/backlight.jsonc",
        "./modules/clean/battery.jsonc",
        "./modules/clean/bluetooth.jsonc",
        "./modules/clean/cpu.jsonc",
        "./modules/clean/disk.jsonc",
        "./modules/clean/groups.jsonc",
        "./modules/clean/memory.jsonc",
        "./modules/clean/network.jsonc",
        "./modules/clean/pulseaudio.jsonc",
        "./modules/clean/temperature.jsonc",
        "./modules/clean/tray.jsonc"
    ],

    "modules-left": [
        "ext/workspaces",
        "custom/vsep#ws",
        "hyprland/window"
    ],
    
    "modules-center": [
        "mpris"
    ],
    
    "modules-right": [
        "privacy",
        "tray",
        "custom/vsep",
        "temperature",
        "group/hardware",
        "custom/vsep",
        "network",
        "bluetooth",
        "backlight",
        "pulseaudio",
        "group/power",
        "custom/vsep",
        "clock"
    ]
}
