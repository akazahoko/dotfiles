// https://github.com/Alexays/Waybar/wiki/Module:-Battery
{
    "battery": {
        "format": "{icon}",
        "format-icons": {
            "default": ["󰂎","󰁺","󰁻","󰁼","󰁽","󰁾","󰁿","󰂀","󰂁","󰂂","󰁹"],
            "charging": ["󰢟","󰢜","󰂆","󰂇","󰂈","󰢝","󰂉","󰢞","󰂊","󰂋","󰂅"]
        },
        "tooltip-format": "Capacity:\t{capacity}%\nTime:\t\t{time}",
        "states": {
            "low": 20
        }
    }
}