// https://github.com/Alexays/Waybar/wiki/Module:-Battery
{
    "battery": {
        "justify": "center",
        "format": "{icon}鈥墈capacity}%",
        "format-icons": {
            "default": ["蟀値","蟀伜","蟀伝","蟀伡","蟀伣","蟀伨","蟀伩","蟀個","蟀倎","蟀倐","蟀伖"],
            "charging": ["蟀","蟀","蟀倖","蟀倗","蟀倛","蟀","蟀倝","蟀","蟀倞","蟀倠","蟀倕"]
        },
        "tooltip-format": "Capacity:\t{capacity}%\nTime:\t\t{time}",
        "states": {
            "low": 20
        }
    }
}