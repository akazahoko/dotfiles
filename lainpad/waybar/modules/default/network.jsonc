{
    "network": {
        "justify": "center",
        "format": "{ifname}",
        "format-ethernet": "≤░ΙΑ",
        "format-linked": "≤░ΙΑ ΎΒ▒",
        // "format-alt": "",
        "format-alt": "<span size='10.5pt'>ΎΒμέΑΚ{bandwidthDownBits}\nΎΒλέΑΚ{bandwidthUpBits}</span>",
        "format-wifi": "{icon}έΑΚέΑΚ{essid}",
        "format-disconnected": "≤░νσέΑΚ",
        "format-disabled": "≤░νφέΑΚ",
