{
    "custom/weather": {
        "exec": "~/.config/waybar/scripts/weather.sh",
        "on-click": "~/.config/waybar/scripts/weather.sh",
        "on-click-middle": "xdg-open https://www.hko.gov.hk",
        "format": "<b>{}</b>",
        "tooltip": false,
        "interval": 3600   // seconds
    }
}